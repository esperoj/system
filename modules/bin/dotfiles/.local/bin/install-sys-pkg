#!/bin/sh
set -eu

# 1. Input Check
if [ "$#" -eq 0 ]; then
    echo "Usage: $0 <pkg1> [pkg2 ...]" >&2
    exit 1
fi

# 2. Privilege & OS Detection
SUDO=""

# Check if we are running on Android (Termux)
if [ -d "/data/data/com.termux" ] || command -v termux-info >/dev/null 2>&1; then
    echo ":: Detected Android/Termux environment. Skipping sudo."
    SUDO=""
# If not Android, check if we are already root
elif [ "$(id -u)" -ne 0 ]; then
    # Not root, so we need sudo
    if command -v sudo >/dev/null 2>&1; then
        SUDO="sudo"
    else
        echo "Warning: Not running as root and 'sudo' is not installed. This may fail." >&2
    fi
fi

# 3. Manager Detection & Execution
if command -v apt-get >/dev/null 2>&1; then
    echo ":: Detected apt. Installing packages..."
    export DEBIAN_FRONTEND=noninteractive
    $SUDO apt-get update
    $SUDO apt-get install -y --no-install-recommends "$@"

elif command -v apk >/dev/null 2>&1; then
    echo ":: Detected apk. Installing packages..."
    $SUDO apk update
    $SUDO apk add --no-cache "$@"

elif command -v pkg >/dev/null 2>&1; then
    echo ":: Detected Termux pkg manager. Installing packages..."
    pkg update
    pkg install -y "$@"

else
    echo "Error: No supported package manager (apt-get, apk, pkg) found." >&2
    exit 1
fi

echo ":: Installation complete."
