#!/bin/sh

# Exit on error
set -e

# Check for input
if [ $# -eq 0 ]; then
    echo "Usage: $0 target1 target2 ..."
    exit 1
fi

# Initialize an empty variable to hold our modified targets
MAKE_TARGETS=""

# Loop through inputs and append -cfg to each
for arg in "$@"; do
    MAKE_TARGETS="$MAKE_TARGETS ${arg}-cfg"
done

echo "==> Running: make$MAKE_TARGETS"

# Execute make once with the full list
# shellcheck disable=SC2086
make $MAKE_TARGETS
